{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SoulCraft Team Schema",
  "description": "Defines a team of SoulCraft souls with sequential or hybrid routing.",
  "type": "object",
  "required": ["metadata", "routing_strategy", "souls"],
  "additionalProperties": false,
  "if": {
    "properties": { "routing_strategy": { "const": "hybrid" } }
  },
  "then": {
    "required": ["metadata", "routing_strategy", "souls", "stages"]
  },
  "else": {
    "not": { "required": ["stages"] }
  },
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["name", "id", "version", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable team name."
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "URL-safe slug, used as directory name under teams/."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of this team definition."
        },
        "description": {
          "type": "string",
          "description": "What this team does."
        }
      }
    },
    "routing_strategy": {
      "type": "string",
      "enum": ["sequential", "hybrid"],
      "description": "How souls interact. 'sequential' = pipeline in array order. 'hybrid' = stages with mixed routing types."
    },
    "souls": {
      "type": "array",
      "minItems": 2,
      "description": "Metadata authority: team_role and directives for each soul. Array order = execution order for sequential routing.",
      "items": {
        "type": "object",
        "required": ["soul_ref", "team_role", "directives"],
        "additionalProperties": false,
        "properties": {
          "soul_ref": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Soul ID — must match a directory under souls/."
          },
          "team_role": {
            "type": "string",
            "description": "This soul's role within the team."
          },
          "directives": {
            "type": "string",
            "description": "Team-specific instructions injected into this soul's Team Context."
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "description": "Execution stages for hybrid routing. Each stage groups souls with a routing type.",
      "items": {
        "type": "object",
        "required": ["name", "type", "souls"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "URL-safe slug for stage name (used as directory name)."
          },
          "type": {
            "type": "string",
            "enum": ["sequential", "iterative", "parallel"],
            "description": "Stage routing type."
          },
          "souls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            },
            "description": "Soul refs in this stage. Must exist in top-level souls array."
          },
          "max_iterations": {
            "type": "integer",
            "minimum": 1,
            "default": 3,
            "description": "Max iterations for iterative stages. Ignored for other types."
          }
        }
      }
    }
  }
}
